{
  "name": "@benedictleejh/nuxt-sanitise-html",
  "version": "1.1.0",
  "description": "A Nuxt module to sanitise HTML to protect against XSS attacks",
  "repository": "benedictleejh/nuxt-sanitise-html",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "nuxt",
    "vue",
    "vue-directive",
    "dom",
    "xss",
    "html",
    "dompurify",
    "security",
    "sanitize",
    "sanitizer"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm lint && pnpm test && pnpm prepack && changelogen --release && pnpm publish --access public && git push --follow-tags && changelogen gh release",
    "lint": "eslint --max-warnings 0 .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "change-case": "^5.4.4",
    "dompurify": "^3.3.1",
    "jsdom": "^27.0.0",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.0",
    "@nuxt/eslint-config": "^1.10.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.2.1",
    "@nuxt/test-utils": "^3.20.1",
    "@types/node": "latest",
    "@types/jsdom": "^27.0.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "nuxt": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.24",
    "vue-tsc": "^3.1.3"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
