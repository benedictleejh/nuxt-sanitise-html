{
  "name": "@benedictleejh/nuxt-sanitise-html",
  "version": "1.1.2",
  "description": "A Nuxt module to sanitise HTML to protect against XSS attacks",
  "repository": "benedictleejh/nuxt-sanitise-html",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "nuxt",
    "vue",
    "vue-directive",
    "dom",
    "xss",
    "html",
    "dompurify",
    "security",
    "sanitize",
    "sanitizer"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm lint && pnpm test && pnpm prepack && changelogen --release && pnpm publish --access public && git push --follow-tags && changelogen gh release",
    "lint": "eslint --max-warnings 0 .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "change-case": "^5.4.4",
    "dompurify": "^3.4.1",
    "jsdom": "^29.0.0",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/node": "latest",
    "@types/jsdom": "^28.0.1",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
